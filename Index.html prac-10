<html>
<body>
    <h3>SIMPLE CALCULATOR</h3>
    <form action="CalcServlet" method="get">
        enter the first number:<br/>
        <input type="text" name="n1"/><br/><br/>
        
        enter the second number:<br/>
        <input type="text" name="n2"/><br/><br/>
        
        enter the operation:<br/><br/>
        <input type="radio" name="opt" value="add"/> add<br/>
        <input type="radio" name="opt" value="sub"/> sub<br/>
        <input type="radio" name="opt" value="mul"/> mul<br/>
        <input type="radio" name="opt" value="div"/> div<br/><br/>
        
        <input type="submit" value="submit"/>
    </form>
</body>
</html>
