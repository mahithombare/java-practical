package practical;

import java.net.*;

public class InetAddressDemo {
    public static void main(String[] args) {
        try {
           
            InetAddress local = InetAddress.getLocalHost();
            System.out.println("--- Local Machine Details ---");
            System.out.println("Host Name: " + local.getHostName());
            System.out.println("IP Address: " + local.getHostAddress());

           
            System.out.println("\n--- Remote Host Details (Single) ---");
            InetAddress remote = InetAddress.getByName("www.google.com");
            System.out.println("Host Name: " + remote.getHostName());
            System.out.println("IP Address: " + remote.getHostAddress());

           
            
            System.out.println("\n--- Remote Host Details (All IPs) ---");
            InetAddress[] allAddresses = InetAddress.getAllByName("www.microsoft.com");
            for (int i = 0; i < allAddresses.length; i++) {
                System.out.println("IP " + (i + 1) + ": " + allAddresses[i].getHostAddress());
            }

        } catch (UnknownHostException e) {
            System.out.println("Host could not be resolved: " + e.getMessage());
        }
    }
}
